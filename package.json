{
  "name": "hooks-abi-dsl",
  "version": "0.1.0",
  "private": true,
  "description": "Declarative decoder for Xahau Hooks state keys and values.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "check": "biome check . && tsc -p tsconfig.check.json --noEmit",
    "dev:viewer": "pnpm --filter state-schema-viewer run dev",
    "format": "biome format --write .",
    "test": "vitest run",
    "validate": "pnpm run check && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.29",
    "state-schema": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.11.0"
}
