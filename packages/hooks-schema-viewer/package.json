{
  "name": "hooks-schema-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "hooks-schema": "workspace:*",
    "xahau": "^4.0.4",
    "xahau-address-codec": "5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^6.3.5"
  }
}
