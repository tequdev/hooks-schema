type Bitmap256 = Bytes(32)
type UserId19 = Bytes(19)

StateKey UserInfoKey {
  Null(11)
  String("U")
  Account user
}

StateValue UserInfoValue {
  Bitmap256 currencySlots
}

State UserInfo = UserInfoKey -> UserInfoValue @priority(100)

State UserCurrencySlot = {
  Null(10)
  String("U")
  u8 currencySlot
  UserId19 user
  u8 userSlot
} -> {
  Currency currency
  Issuer issuer
} @priority(100)
